<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClinicManagementSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClinicManagementSystem.styles.css" asp-append-version="true" />
    <style>

            /* Page Navigation Bar */
            .page-nav {
                position: sticky;
                top: 80px; /* below fixed header */
                z-index: 999;
            }

            /* Buttons */
            .nav-btn {
                margin: 0 15px;
                text-decoration: none;
                font-weight: 500;
                color: #333;
                transition: 0.3s;
            }

                .nav-btn:hover {
                    color: #3a8dff;
                }

            /* Login Button */
            .login-btn {
                background: #3a8dff;
                color: white !important;
                padding: 6px 15px;
                border-radius: 6px;
            }

                .login-btn:hover {
                    background: #2c6ed5;
                }

            .custom-navbar {
                background: linear-gradient(90deg, #0f2027, #203a43, #2c5364);
            }

            /* Logo text styling */
            .logo-text {
                font-size: 24px;
                font-weight: 600;
            }

                /* Clinic color */
                .logo-text .clinic {
                    color: #ffffff;
                }

                /* MS highlight */
                .logo-text .ms {
                    color: #3a8dff;
                    font-weight: 700;
                    text-shadow: 0 0 5px rgba(58,141,255,0.5);
                }

            .register-link {
                font-size: 14px;
                color: #6c757d;
                text-decoration: none;
                transition: 0.3s;
            }

                .register-link:hover {
                    color: #3a8dff;
                    text-decoration: underline;
                }
            body {
                height: 100%;
                margin: 0;
                padding-top: 70px;
            }

            html {
                height: 100%;
                scroll-behavior: smooth;
            }

            footer {
                width: 100%;
            }

            header{
                width:100%;
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg fixed-top custom-navbar">
            <div class="container-fluid px-5">
                <a class="navbar-brand d-flex align-items-center" href="/">
                    <img src="/images/logo.png" height="45" class="me-2" />

                    <span class="logo-text">
                        <span class="clinic">Clinic</span><span class="ms">MS</span>
                    </span>
                </a>

            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="flex-grow-1">
            @RenderBody()
        </main>
    </div>

    <footer id="contact" class="bg-dark text-white mt-auto">
        <div class="container py-4">
            <div class="row text-center text-md-start">

                <div class="col-md-4">
                    <h5>ClinicMS</h5>
                    <p>Providing quality healthcare services with modern technology.</p>
                </div>

                <div class="col-md-4">
                    <h6>Contact</h6>
                    <p class="mb-1">+91 98765 43210</p>
                    <p class="mb-1">support@clinicms.com</p>
                </div>

                <div class="col-md-4">
                    <h6>Address</h6>
                    <p>123 Health Street,<br>Hyderabad, India</p>
                </div>

            </div>

            <div class="text-center mt-3">
                © 2026 ClinicMS. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

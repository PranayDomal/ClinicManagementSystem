@{
    ViewData["Title"] = "Register";
}

@model ClinicManagementSystem.Models.RegisterViewModel

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 85vh;">
    
    <div class="card shadow p-4" style="width: 400px;">

        <h3 class="text-center mb-4">Patient Registration</h3>

        <form method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <!-- Name -->
            <div class="mb-3">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" placeholder="Enter your full name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- Email -->
            <div class="mb-3">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-control" placeholder="abc@domain.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Password -->
            <div class="mb-3">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <!-- Confirm Password -->
            <div class="mb-3">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <!-- Server Error -->
            @if (ViewBag.Error != null)
            {
                <div class="text-danger mb-2">
                    @ViewBag.Error
                </div>
            }

            <!-- Submit -->
            <button type="submit" class="btn btn-success w-100">
                Register
            </button>

        </form>

        <!-- Back to Login -->
        <div class="text-center mt-3">
            <a href="/Auth/Login" class="register-link">
                Already have an account? Login
            </a>
        </div>

    </div>

</div>